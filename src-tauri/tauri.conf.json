{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hayamiru",
  "version": "0.1.0",
  "identifier": "com.mochi.hayamiru",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hayamiru",
        "width": 854,
        "height": 480,
        "minWidth": 640,
        "minHeight": 360,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["binaries/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["mp4", "mkv", "avi", "mov", "webm", "flv", "wmv", "m4v", "ts", "mpg", "mpeg"],
        "mimeType": "video/*",
        "description": "Video File"
      },
      {
        "ext": ["mp3", "flac", "ogg", "wav", "aac", "wma", "m4a", "opus"],
        "mimeType": "audio/*",
        "description": "Audio File"
      }
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installMode": "perMachine"
      }
    }
  }
}
